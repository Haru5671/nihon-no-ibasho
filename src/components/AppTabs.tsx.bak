"use client";

import { useState } from "react";
import Hiroba from "./Hiroba";
import Kobeya from "./Kobeya";
import IbashoPersonal from "./IbashoPersonal";

const tabs = [
  { id: "hiroba", label: "広場" },
  { id: "kobeya", label: "小部屋" },
  { id: "personal", label: "いばしょパーソナル" },
] as const;

type TabId = (typeof tabs)[number]["id"];

export default function AppTabs() {
  const [active, setActive] = useState<TabId>("hiroba");

  return (
    <section className="bg-[#f8fafb] min-h-screen">
      {/* Tab bar */}
      <div className="sticky top-16 z-40 bg-white/95 backdrop-blur-md border-b border-gray-200">
        <div className="max-w-3xl mx-auto flex">
          {tabs.map((tab) => (
            <button
              key={tab.id}
              onClick={() => setActive(tab.id)}
              className={`flex-1 py-3 text-sm font-medium transition-colors relative ${
                active === tab.id
                  ? "text-teal-600"
                  : "text-gray-400 hover:text-gray-600"
              }`}
            >
              {tab.label}
              {active === tab.id && (
                <span className="absolute bottom-0 left-1/4 right-1/4 h-0.5 bg-teal-500 rounded-full" />
              )}
            </button>
          ))}
        </div>
      </div>

      {/* Tab content */}
      <div className="px-4 py-8">
        {active === "hiroba" && <Hiroba />}
        {active === "kobeya" && <Kobeya />}
        {active === "personal" && <IbashoPersonal />}
      </div>
    </section>
  );
}
